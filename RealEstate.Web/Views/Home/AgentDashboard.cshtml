@{
    ViewData["Title"] = "Agent Dashboard";
    var token = ViewBag.Token as string ?? "";
}

<div class="bg-primary text-white py-4">
    <div class="container">
        <h3 class="fw-bold mb-0">
            <i class="fas fa-tachometer-alt me-2"></i>Agent Dashboard
        </h3>
        <p class="mb-0 opacity-75">Welcome back, @ViewBag.FullName!</p>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4">

        <!-- Stats -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-4">
                <i class="fas fa-building fa-2x text-primary mb-2"></i>
                <h3 class="fw-bold" id="propCount">0</h3>
                <p class="text-muted mb-0">My Properties</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-4">
                <i class="fas fa-envelope fa-2x text-warning mb-2"></i>
                <h3 class="fw-bold" id="inqCount">0</h3>
                <p class="text-muted mb-0">Inquiries</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-4">
                <i class="fas fa-calendar fa-2x text-success mb-2"></i>
                <h3 class="fw-bold" id="bookCount">0</h3>
                <p class="text-muted mb-0">Visit Bookings</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-4">
                <i class="fas fa-rupee-sign fa-2x text-danger mb-2"></i>
                <h3 class="fw-bold" id="portfolioValue">0</h3>
                <p class="text-muted mb-0">Portfolio Value</p>
            </div>
        </div>

        <!-- Analytics Charts -->
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-bold">
                    <i class="fas fa-chart-line me-2 text-primary"></i>Analytics
                    <span class="badge bg-primary ms-2">Live Data</span>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <!-- Monthly Inquiries Line Chart -->
                        <div class="col-md-6">
                            <h6 class="fw-bold text-muted mb-3">
                                <i class="fas fa-chart-line me-2 text-primary"></i>
                                Monthly Inquiries (Last 6 Months)
                            </h6>
                            <canvas id="monthlyChart" height="200"></canvas>
                        </div>
                        <!-- Inquiries per Property Bar Chart -->
                        <div class="col-md-6">
                            <h6 class="fw-bold text-muted mb-3">
                                <i class="fas fa-chart-bar me-2 text-warning"></i>
                                Inquiries per Property
                            </h6>
                            <canvas id="inquiryChart" height="200"></canvas>
                        </div>
                        <!-- Property Type Pie Chart -->
                        <div class="col-md-4">
                            <h6 class="fw-bold text-muted mb-3">
                                <i class="fas fa-chart-pie me-2 text-success"></i>
                                Property Type Distribution
                            </h6>
                            <canvas id="typeChart" height="200"></canvas>
                        </div>
                        <!-- Booking Stats Bar Chart -->
                        <div class="col-md-4">
                            <h6 class="fw-bold text-muted mb-3">
                                <i class="fas fa-chart-bar me-2 text-danger"></i>
                                Booking Status
                            </h6>
                            <canvas id="bookingChart" height="200"></canvas>
                        </div>
                        <!-- Inquiry Status Doughnut -->
                        <div class="col-md-4">
                            <h6 class="fw-bold text-muted mb-3">
                                <i class="fas fa-circle-notch me-2 text-info"></i>
                                Inquiry Status
                            </h6>
                            <canvas id="inquiryStatusChart" height="200"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Add Property -->
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-bold d-flex justify-content-between">
                    <span><i class="fas fa-plus me-2 text-primary"></i>Add New Property</span>
                    <button class="btn btn-sm btn-primary" onclick="toggleForm()">
                        + Add Property
                    </button>
                </div>
                <div class="card-body" id="addPropertyForm" style="display:none;">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <input type="text" class="form-control" id="title" placeholder="Title" />
                        </div>
                        <div class="col-md-6">
                            <input type="text" class="form-control" id="city" placeholder="City" />
                        </div>
                        <div class="col-md-12">
                            <textarea class="form-control" id="description" rows="2"
                                      placeholder="Description"></textarea>
                        </div>
                        <div class="col-md-3">
                            <input type="number" class="form-control" id="price" placeholder="Price" />
                        </div>
                        <div class="col-md-3">
                            <input type="number" class="form-control" id="areaSqFt" placeholder="Area SqFt" />
                        </div>
                        <div class="col-md-3">
                            <input type="number" class="form-control" id="bedrooms" placeholder="Bedrooms" />
                        </div>
                        <div class="col-md-3">
                            <input type="number" class="form-control" id="bathrooms" placeholder="Bathrooms" />
                        </div>
                        <div class="col-md-6">
                            <input type="text" class="form-control" id="address" placeholder="Address" />
                        </div>
                        <div class="col-md-3">
                            <select class="form-select" id="propertyType">
                                <option value="Villa">Villa</option>
                                <option value="Apartment">Apartment</option>
                                <option value="House">House</option>
                                <option value="Plot">Plot</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select class="form-select" id="listingType">
                                <option value="Sale">Sale</option>
                                <option value="Rent">Rent</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <button class="btn btn-primary" onclick="addProperty()">
                                <i class="fas fa-save me-2"></i>Save Property
                            </button>
                            <div id="addResult" class="d-inline-block ms-2"></div>
                        </div>
                        <div class="col-12" id="uploadImageSection" style="display:none;">
                            <hr />
                            <h6 class="fw-bold">Upload Property Image</h6>
                            <div class="d-flex gap-2">
                                <input type="file" class="form-control" id="imageFile" accept="image/*" />
                                <button class="btn btn-outline-primary" onclick="uploadImage()">
                                    <i class="fas fa-upload me-1"></i>Upload
                                </button>
                            </div>
                            <div id="uploadResult" class="mt-2"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- My Properties -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-bold">
                    <i class="fas fa-building me-2 text-primary"></i>My Properties
                </div>
                <div class="card-body" id="propertiesList">
                    <div class="text-center py-3">
                        <div class="spinner-border spinner-border-sm text-primary"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Inquiries -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-bold">
                    <i class="fas fa-envelope me-2 text-warning"></i>Recent Inquiries
                </div>
                <div class="card-body" id="inquiriesList">
                    <div class="text-center py-3">
                        <div class="spinner-border spinner-border-sm text-primary"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Visit Bookings -->
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-bold">
                    <i class="fas fa-calendar me-2 text-success"></i>Visit Bookings
                </div>
                <div class="card-body" id="bookingsList">
                    <div class="text-center py-3">
                        <div class="spinner-border spinner-border-sm text-primary"></div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const token = "@token";
        const properties = @Html.Raw(ViewBag.PropertiesJson != null ?
                    System.Text.Json.JsonSerializer.Serialize(
                            System.Text.Json.JsonDocument.Parse(
                                    ViewBag.PropertiesJson).RootElement.GetProperty("data")) : "[]");
    const inquiries = @Html.Raw(ViewBag.InquiriesJson ?? "[]");
    const bookings = @Html.Raw(ViewBag.BookingsJson ?? "[]");

        // Stats
        document.getElementById('propCount').textContent = properties.length;
        document.getElementById('inqCount').textContent = inquiries.length;
        document.getElementById('bookCount').textContent = bookings.length;

        // Load Analytics Charts
        async function loadAnalytics() {
            try {
                const response = await fetch('https://localhost:7056/api/Agents/analytics', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if (!response.ok) return;
                const data = await response.json();

                // Portfolio Value
                document.getElementById('portfolioValue').textContent =
                    '₹' + (data.totalValue / 10000000).toFixed(1) + 'Cr';

                // Monthly Inquiries Line Chart
                new Chart(document.getElementById('monthlyChart'), {
                    type: 'line',
                    data: {
                        labels: data.monthlyInquiries.map(m => m.month),
                        datasets: [{
                            label: 'Inquiries',
                            data: data.monthlyInquiries.map(m => m.count),
                            borderColor: '#2563eb',
                            backgroundColor: 'rgba(37,99,235,0.1)',
                            fill: true,
                            tension: 0.4,
                            pointBackgroundColor: '#2563eb',
                            pointRadius: 5
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { beginAtZero: true, ticks: { stepSize: 1 } }
                        }
                    }
                });

                // Inquiries per Property Bar Chart
                new Chart(document.getElementById('inquiryChart'), {
                    type: 'bar',
                    data: {
                        labels: data.inquiriesPerProperty.map(p => p.propertyTitle),
                        datasets: [{
                            label: 'Inquiries',
                            data: data.inquiriesPerProperty.map(p => p.inquiryCount),
                            backgroundColor: [
                                '#2563eb','#f59e0b','#10b981',
                                '#ef4444','#8b5cf6','#06b6d4','#f97316'
                            ],
                            borderRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                    }
                });

                // Property Type Pie Chart
                new Chart(document.getElementById('typeChart'), {
                    type: 'pie',
                    data: {
                        labels: data.propertyTypeDistribution.map(t => t.type),
                        datasets: [{
                            data: data.propertyTypeDistribution.map(t => t.count),
                            backgroundColor: ['#2563eb','#f59e0b','#10b981','#ef4444'],
                            borderWidth: 2,
                            borderColor: '#fff'
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { position: 'bottom' }
                        }
                    }
                });

                // Booking Status Bar Chart
                new Chart(document.getElementById('bookingChart'), {
                    type: 'bar',
                    data: {
                        labels: ['Pending', 'Confirmed', 'Cancelled'],
                        datasets: [{
                            label: 'Bookings',
                            data: [
                                data.bookingStats.pending,
                                data.bookingStats.confirmed,
                                data.bookingStats.cancelled
                            ],
                            backgroundColor: ['#f59e0b', '#10b981', '#ef4444'],
                            borderRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                    }
                });

                // Inquiry Status Doughnut
                new Chart(document.getElementById('inquiryStatusChart'), {
                    type: 'doughnut',
                    data: {
                        labels: ['Replied', 'Pending'],
                        datasets: [{
                            data: [data.repliedInquiries, data.pendingInquiries],
                            backgroundColor: ['#10b981', '#f59e0b'],
                            borderWidth: 2,
                            borderColor: '#fff'
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { position: 'bottom' } }
                    }
                });

            } catch(e) {
                console.error('Analytics error:', e);
            }
        }

        loadAnalytics();

        // Properties List
        if (properties.length > 0) {
            document.getElementById('propertiesList').innerHTML = properties.map(p => `
                <div class="border-bottom pb-2 mb-2 d-flex justify-content-between align-items-center">
                    <div>
                        <p class="fw-bold mb-0 small">${p.title}</p>
                        <small class="text-muted">${p.city} • ₹${p.price.toLocaleString('en-IN')}</small>
                    </div>
                    <span class="badge bg-${p.status === 'Available' ? 'success' : 'secondary'}">
                        ${p.status}
                    </span>
                </div>
            `).join('');
        } else {
            document.getElementById('propertiesList').innerHTML =
                '<p class="text-muted text-center">No properties yet!</p>';
        }

        // Inquiries List
        if (inquiries.length > 0) {
            document.getElementById('inquiriesList').innerHTML = inquiries.map(i => `
                <div class="border-bottom pb-2 mb-2">
                    <p class="fw-bold mb-1 small">${i.message}</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="badge ${i.isReplied ? 'bg-success' : 'bg-warning text-dark'}">
                            ${i.isReplied ? 'Replied' : 'Pending'}
                        </span>
                        ${!i.isReplied ? `
                            <button class="btn btn-sm btn-outline-primary"
                                onclick="replyInquiry('${i.id}')">
                                Reply
                            </button>` : ''}
                    </div>
                </div>
            `).join('');
        } else {
            document.getElementById('inquiriesList').innerHTML =
                '<p class="text-muted text-center">No inquiries yet!</p>';
        }

        // Bookings Table
        if (bookings.length > 0) {
            document.getElementById('bookingsList').innerHTML = `
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Visit Date</th>
                                <th>Notes</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${bookings.map(b => `
                                <tr>
                                    <td>${new Date(b.visitDate).toLocaleDateString()}</td>
                                    <td>${b.notes ?? '-'}</td>
                                    <td>
                                        <span class="badge ${
                                            b.status === 'Confirmed' ? 'bg-success' :
                                            b.status === 'Cancelled' ? 'bg-danger' :
                                            'bg-warning text-dark'}">
                                            ${b.status}
                                        </span>
                                    </td>
                                    <td>
                                        ${b.status === 'Pending' ? `
                                            <button class="btn btn-sm btn-success"
                                                onclick="confirmBooking('${b.id}')">
                                                Confirm
                                            </button>` : '-'}
                                    </td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>`;
        } else {
            document.getElementById('bookingsList').innerHTML =
                '<p class="text-muted text-center">No bookings yet!</p>';
        }

        function toggleForm() {
            const form = document.getElementById('addPropertyForm');
            form.style.display = form.style.display === 'none' ? 'block' : 'none';
        }

        let newPropertyId = null;

        async function addProperty() {
            const property = {
                title: document.getElementById('title').value,
                description: document.getElementById('description').value,
                price: parseFloat(document.getElementById('price').value),
                areaSqFt: parseFloat(document.getElementById('areaSqFt').value),
                bedrooms: parseInt(document.getElementById('bedrooms').value),
                bathrooms: parseInt(document.getElementById('bathrooms').value),
                address: document.getElementById('address').value,
                city: document.getElementById('city').value,
                propertyType: document.getElementById('propertyType').value,
                listingType: document.getElementById('listingType').value,
                isFeatured: false,
                latitude: 0,
                longitude: 0
            };

            const response = await fetch('https://localhost:7056/api/Properties', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify(property)
            });

            if (response.ok) {
                const data = await response.json();
                newPropertyId = data.id;
                document.getElementById('addResult').innerHTML =
                    '<span class="text-success">✅ Property added!</span>';
                document.getElementById('uploadImageSection').style.display = 'block';
            } else {
                document.getElementById('addResult').innerHTML =
                    '<span class="text-danger">❌ Failed to add property!</span>';
            }
        }

        async function uploadImage() {
            const fileInput = document.getElementById('imageFile');
            if (!fileInput.files[0]) { alert('Please select an image!'); return; }
            if (!newPropertyId) { alert('Please save property first!'); return; }

            const formData = new FormData();
            formData.append('file', fileInput.files[0]);

            const response = await fetch(`https://localhost:7056/api/Properties/${newPropertyId}/images`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}` },
                body: formData
            });

            if (response.ok) {
                document.getElementById('uploadResult').innerHTML =
                    '<div class="alert alert-success">✅ Image uploaded!</div>';
                setTimeout(() => location.reload(), 1500);
            } else {
                document.getElementById('uploadResult').innerHTML =
                    '<div class="alert alert-danger">❌ Upload failed!</div>';
            }
        }

        async function confirmBooking(id) {
            const response = await fetch(`https://localhost:7056/api/VisitBookings/${id}/confirm`, {
                method: 'PUT',
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (response.ok) location.reload();
        }

        async function replyInquiry(id) {
            const reply = prompt('Enter your reply:');
            if (!reply) return;

            const response = await fetch(`https://localhost:7056/api/Inquiries/${id}/reply`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify(reply)
            });
            if (response.ok) location.reload();
        }
    </script>
}