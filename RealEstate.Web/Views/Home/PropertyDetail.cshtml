@{
    ViewData["Title"] = "Property Detail";
    var isLoggedIn = ViewBag.IsLoggedIn ?? false;
    var token = ViewBag.Token as string ?? "";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />

<div class="container py-5">
    <div id="propertyDetail">
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Loading property...</p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    <script>
        const json = @Html.Raw(ViewBag.PropertyJson ?? "null");
        const isLoggedIn = @Html.Raw(isLoggedIn.ToString().ToLower());
        const token = "@token";
        const userRole = "@Context.Session.GetString("Role")";
        const buyerName = "@Context.Session.GetString("FullName")";
        const buyerEmail = "@Context.Session.GetString("Email")";

        if (json) {
            document.getElementById('propertyDetail').innerHTML = `
                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                        <li class="breadcrumb-item"><a href="/Home/Properties">Properties</a></li>
                        <li class="breadcrumb-item active">${json.title}</li>
                    </ol>
                </nav>
                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="card border-0 shadow-sm mb-4">
                            <div style="height:350px; overflow:hidden;">
                                ${json.imageUrls && json.imageUrls.length > 0 ? `
                                    <img src="${json.imageUrls[0].startsWith('http') ? json.imageUrls[0] : 'https://localhost:7056' + json.imageUrls[0]}"
                                        class="w-100 h-100" style="object-fit:cover;" />
                                ` : `
                                    <div class="bg-light d-flex align-items-center justify-content-center h-100">
                                        <i class="fas fa-home fa-5x text-secondary"></i>
                                    </div>
                                `}
                            </div>
                        </div>
                        <div class="card border-0 shadow-sm p-4 mb-4">
                            <h2 class="fw-bold">${json.title}</h2>
                            <p class="text-muted">
                                <i class="fas fa-map-marker-alt me-2 text-primary"></i>
                                ${json.address}, ${json.city}
                            </p>
                            <div class="d-flex gap-2 mb-3">
                                <span class="badge bg-primary">${json.propertyType}</span>
                                <span class="badge bg-success">${json.listingType}</span>
                                <span class="badge bg-secondary">${json.status}</span>
                            </div>
                            <h3 class="text-primary fw-bold">
                                ₹${json.price.toLocaleString('en-IN')}
                            </h3>
                            <hr/>
                            <h5 class="fw-bold">Description</h5>
                            <p class="text-muted">${json.description}</p>
                            <hr/>
                            <h5 class="fw-bold">Property Details</h5>
                            <div class="row g-3">
                                <div class="col-md-3 text-center">
                                    <div class="card bg-light border-0 p-3">
                                        <i class="fas fa-bed fa-2x text-primary mb-2"></i>
                                        <h5 class="fw-bold mb-0">${json.bedrooms}</h5>
                                        <small class="text-muted">Bedrooms</small>
                                    </div>
                                </div>
                                <div class="col-md-3 text-center">
                                    <div class="card bg-light border-0 p-3">
                                        <i class="fas fa-bath fa-2x text-primary mb-2"></i>
                                        <h5 class="fw-bold mb-0">${json.bathrooms}</h5>
                                        <small class="text-muted">Bathrooms</small>
                                    </div>
                                </div>
                                <div class="col-md-3 text-center">
                                    <div class="card bg-light border-0 p-3">
                                        <i class="fas fa-ruler-combined fa-2x text-primary mb-2"></i>
                                        <h5 class="fw-bold mb-0">${json.areaSqFt}</h5>
                                        <small class="text-muted">Sq.Ft</small>
                                    </div>
                                </div>
                                <div class="col-md-3 text-center">
                                    <div class="card bg-light border-0 p-3">
                                        <i class="fas fa-eye fa-2x text-primary mb-2"></i>
                                        <h5 class="fw-bold mb-0">${json.viewCount}</h5>
                                        <small class="text-muted">Views</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        ${json.latitude && json.longitude && json.latitude != 0 ? `
                        <div class="card border-0 shadow-sm p-4">
                            <h5 class="fw-bold mb-3">
                                <i class="fas fa-map-marker-alt me-2 text-primary"></i>Location
                            </h5>
                            <div id="map" style="height:400px; border-radius:12px;"></div>
                        </div>
                        ` : ''}
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm p-4 mb-4">
                            <h5 class="fw-bold mb-3">❤️ Save Property</h5>
                            ${isLoggedIn ? `
                                <button class="btn btn-outline-danger w-100" onclick="addFavorite('${json.id}')">
                                    <i class="fas fa-heart me-2"></i>Add to Favorites
                                </button>
                                <div id="favoriteResult" class="mt-2"></div>
                            ` : `
                                <a href="/Auth/Login" class="btn btn-outline-danger w-100">
                                    <i class="fas fa-heart me-2"></i>Login to Save
                                </a>
                            `}
                        </div>
                        ${userRole !== 'Agent' ? `
                        <div class="card border-0 shadow-sm p-4 mb-4">
                            <h5 class="fw-bold mb-3">📩 Send Inquiry</h5>
                            ${isLoggedIn ? `
                                <div class="mb-3">
                                    <textarea class="form-control" id="inquiryMessage" rows="4"
                                        placeholder="I am interested in this property..."></textarea>
                                </div>
                                <button class="btn btn-primary w-100" onclick="sendInquiry('${json.id}')">
                                    <i class="fas fa-paper-plane me-2"></i>Send Message
                                </button>
                                <div id="inquiryResult" class="mt-2"></div>
                            ` : `
                                <p class="text-muted">Please login to send an inquiry</p>
                                <a href="/Auth/Login" class="btn btn-outline-primary w-100">
                                    <i class="fas fa-sign-in-alt me-2"></i>Login to Inquire
                                </a>
                            `}
                        </div>
                        <div class="card border-0 shadow-sm p-4">
                            <h5 class="fw-bold mb-3">📅 Book a Visit</h5>
                            ${isLoggedIn ? `
                                <div class="mb-3">
                                    <input type="datetime-local" class="form-control" id="visitDate" />
                                </div>
                                <div class="mb-3">
                                    <input type="text" class="form-control" id="visitNotes"
                                        placeholder="Any notes for the agent?" />
                                </div>
                                <button class="btn btn-outline-primary w-100" onclick="bookVisit('${json.id}')">
                                    <i class="fas fa-calendar me-2"></i>Book Visit & Pay Deposit
                                </button>
                                <div id="visitResult" class="mt-2"></div>
                            ` : `
                                <p class="text-muted">Please login to book a visit</p>
                                <a href="/Auth/Login" class="btn btn-outline-primary w-100">
                                    <i class="fas fa-sign-in-alt me-2"></i>Login to Book
                                </a>
                            `}
                        </div>
                        ` : ''}
                    </div>
                </div>
            `;

            if (json.latitude && json.longitude && json.latitude != 0) {
                setTimeout(() => {
                    const map = L.map('map').setView([json.latitude, json.longitude], 15);
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
                    L.marker([json.latitude, json.longitude])
                        .addTo(map)
                        .bindPopup(`<b>${json.title}</b><br>${json.address}, ${json.city}`)
                        .openPopup();
                }, 500);
            }

        } else {
            document.getElementById('propertyDetail').innerHTML = `
                <div class="text-center py-5">
                    <i class="fas fa-exclamation-triangle fa-3x text-warning mb-3"></i>
                    <h4>Property not found!</h4>
                    <a href="/Home/Properties" class="btn btn-primary">Back to Properties</a>
                </div>`;
        }

        async function sendInquiry(propertyId) {
            const message = document.getElementById('inquiryMessage').value;
            if (!message) { alert('Please enter a message!'); return; }
            const response = await fetch('https://localhost:7056/api/Inquiries', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify({ propertyId, message })
            });
            if (response.ok) {
                document.getElementById('inquiryResult').innerHTML =
                    '<div class="alert alert-success mt-2">✅ Inquiry sent successfully!</div>';
            } else {
                document.getElementById('inquiryResult').innerHTML =
                    '<div class="alert alert-danger mt-2">❌ Failed to send inquiry!</div>';
            }
        }

        async function bookVisit(propertyId) {
            const visitDate = document.getElementById('visitDate').value;
            const notes = document.getElementById('visitNotes').value;
            if (!visitDate) { alert('Please select a date!'); return; }
            const response = await fetch('https://localhost:7056/api/VisitBookings', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify({ propertyId, visitDate, notes })
            });
            if (response.ok) {
                const bookingData = await response.json();
                document.getElementById('visitResult').innerHTML =
                    '<div class="alert alert-success mt-2">✅ Visit booked! Opening payment...</div>';
               setTimeout(() => payDeposit(bookingData.id, 1000), 1000);
            } else {
                document.getElementById('visitResult').innerHTML =
                    '<div class="alert alert-danger mt-2">❌ Failed to book visit!</div>';
            }
        }

        async function addFavorite(propertyId) {
            const response = await fetch('https://localhost:7056/api/Favorites', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify({ propertyId })
            });
            if (response.ok) {
                document.getElementById('favoriteResult').innerHTML =
                    '<div class="alert alert-success mt-2">❤️ Added to favorites!</div>';
            } else {
                document.getElementById('favoriteResult').innerHTML =
                    '<div class="alert alert-danger mt-2">❌ Failed to add!</div>';
            }
        }

        async function payDeposit(bookingId, amount) {
            try {
                const orderRes = await fetch('https://localhost:7056/api/Payments/create-order', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({ bookingId, amount })
                });
                const order = await orderRes.json();

                const options = {
                    key: order.keyId,
                    amount: order.amount,
                    currency: order.currency,
                    name: 'RealEstate App',
                    description: 'Visit Booking Deposit',
                    order_id: order.orderId,
                    handler: async function(response) {
                        const verifyRes = await fetch('https://localhost:7056/api/Payments/verify', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'Authorization': `Bearer ${token}`
                            },
                            body: JSON.stringify({
                                bookingId: bookingId,
                                amount: amount,
                                razorpayOrderId: response.razorpay_order_id,
                                razorpayPaymentId: response.razorpay_payment_id,
                                razorpaySignature: response.razorpay_signature
                            })
                        });
                        if (verifyRes.ok) {
                            document.getElementById('visitResult').innerHTML =
                                '<div class="alert alert-success mt-2">✅ Payment successful! Visit confirmed!</div>';
                        } else {
                            document.getElementById('visitResult').innerHTML =
                                '<div class="alert alert-danger mt-2">❌ Payment verification failed!</div>';
                        }
                    },
                    prefill: { name: buyerName, email: buyerEmail },
                    theme: { color: '#2563eb' }
                };

                const rzp = new Razorpay(options);
                rzp.open();
            } catch(e) {
                console.error('Payment error:', e);
            }
        }
    </script>
}