@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div class="hero text-white">
    <div class="container text-center py-5">
        <h1 class="display-4 fw-bold mb-3">
            <i class="fas fa-home me-3"></i>Find Your Dream Home
        </h1>
        <p class="lead mb-4">Discover thousands of properties across India</p>

        <!-- Search Bar -->
        <div class="card shadow-lg mx-auto" style="max-width: 700px;">
            <div class="card-body p-4">
                <form action="/Home/Properties" method="get">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <input type="text" name="city" class="form-control form-control-lg"
                                   placeholder="🏙️ City" />
                        </div>
                        <div class="col-md-4">
                            <select name="propertyType" class="form-select form-select-lg">
                                <option value="">🏠 Property Type</option>
                                <option>Villa</option>
                                <option>Apartment</option>
                                <option>House</option>
                                <option>Plot</option>
                                <option>Commercial</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <select name="listingType" class="form-select form-select-lg">
                                <option value="">💰 Listing Type</option>
                                <option>Sale</option>
                                <option>Rent</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary btn-lg w-100">
                                <i class="fas fa-search me-2"></i>Search Properties
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Stats Section -->
<div class="bg-light py-4">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-3">
                <h3 class="text-primary fw-bold">500+</h3>
                <p class="text-muted">Properties Listed</p>
            </div>
            <div class="col-md-3">
                <h3 class="text-primary fw-bold">200+</h3>
                <p class="text-muted">Happy Clients</p>
            </div>
            <div class="col-md-3">
                <h3 class="text-primary fw-bold">50+</h3>
                <p class="text-muted">Expert Agents</p>
            </div>
            <div class="col-md-3">
                <h3 class="text-primary fw-bold">10+</h3>
                <p class="text-muted">Cities Covered</p>
            </div>
        </div>
    </div>
</div>

<!-- Featured Properties -->
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">🏆 Featured Properties</h2>
        <a href="/Home/Properties" class="btn btn-outline-primary">View All</a>
    </div>

    <div class="row g-4" id="featuredProperties">
        <div class="col-12 text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Loading properties...</p>
        </div>
    </div>
</div>

<!-- Property Type Section -->
<div class="bg-light py-5">
    <div class="container">
        <h2 class="fw-bold text-center mb-4">Browse by Type</h2>
        <div class="row g-3 text-center">
            <div class="col-md-2 col-4">
                <a href="/Home/Properties?propertyType=Villa" class="text-decoration-none">
                    <div class="card border-0 shadow-sm p-3">
                        <i class="fas fa-home fa-2x text-primary mb-2"></i>
                        <small class="fw-bold">Villa</small>
                    </div>
                </a>
            </div>
            <div class="col-md-2 col-4">
                <a href="/Home/Properties?propertyType=Apartment" class="text-decoration-none">
                    <div class="card border-0 shadow-sm p-3">
                        <i class="fas fa-building fa-2x text-primary mb-2"></i>
                        <small class="fw-bold">Apartment</small>
                    </div>
                </a>
            </div>
            <div class="col-md-2 col-4">
                <a href="/Home/Properties?propertyType=House" class="text-decoration-none">
                    <div class="card border-0 shadow-sm p-3">
                        <i class="fas fa-house fa-2x text-primary mb-2"></i>
                        <small class="fw-bold">House</small>
                    </div>
                </a>
            </div>
            <div class="col-md-2 col-4">
                <a href="/Home/Properties?propertyType=Plot" class="text-decoration-none">
                    <div class="card border-0 shadow-sm p-3">
                        <i class="fas fa-map fa-2x text-primary mb-2"></i>
                        <small class="fw-bold">Plot</small>
                    </div>
                </a>
            </div>
            <div class="col-md-2 col-4">
                <a href="/Home/Properties?listingType=Rent" class="text-decoration-none">
                    <div class="card border-0 shadow-sm p-3">
                        <i class="fas fa-key fa-2x text-primary mb-2"></i>
                        <small class="fw-bold">Rent</small>
                    </div>
                </a>
            </div>
            <div class="col-md-2 col-4">
                <a href="/Home/Properties?listingType=Sale" class="text-decoration-none">
                    <div class="card border-0 shadow-sm p-3">
                        <i class="fas fa-tag fa-2x text-primary mb-2"></i>
                        <small class="fw-bold">Sale</small>
                    </div>
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Load featured properties from API
        const json = @Html.Raw(ViewBag.PropertiesJson ?? "null");

        if (json && json.data && json.data.length > 0) {
            const container = document.getElementById('featuredProperties');
            container.innerHTML = json.data.map(p => `
                <div class="col-md-4">
                    <div class="card property-card shadow-sm h-100">
                        <div class="position-relative">
                                    <div class="property-img bg-light" style="overflow:hidden;">
            ${p.imageUrls && p.imageUrls.length > 0 ? `
                <img src="https://localhost:7056${p.imageUrls[0]}"
                    class="w-100 h-100" style="object-fit:cover;" />
            ` : `
                <i class="fas fa-home fa-3x text-secondary"></i>
            `}
        </div>
                            <span class="badge bg-primary badge-type">${p.propertyType}</span>
                            ${p.isFeatured ? '<span class="badge bg-warning badge-featured">⭐ Featured</span>' : ''}
                        </div>
                        <div class="card-body">
                            <h6 class="card-title fw-bold">${p.title}</h6>
                            <p class="text-muted small"><i class="fas fa-map-marker-alt me-1"></i>${p.address}, ${p.city}</p>
                            <div class="price-tag">₹${p.price.toLocaleString('en-IN')}</div>
                            <div class="d-flex gap-3 mt-2 text-muted small">
                                <span><i class="fas fa-bed me-1"></i>${p.bedrooms} Beds</span>
                                <span><i class="fas fa-bath me-1"></i>${p.bathrooms} Baths</span>
                                <span><i class="fas fa-ruler-combined me-1"></i>${p.areaSqFt} sqft</span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0">
                            <a href="/Home/PropertyDetail/${p.id}" class="btn btn-primary w-100">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            `).join('');
        } else {
            document.getElementById('featuredProperties').innerHTML = `
                <div class="col-12 text-center py-5">
                    <i class="fas fa-home fa-3x text-muted mb-3"></i>
                    <p class="text-muted">No featured properties yet!</p>
                    <a href="/Home/Properties" class="btn btn-primary">Browse All Properties</a>
                </div>`;
        }
    </script>
}