@{
    ViewData["Title"] = "My Inquiries";
    var token = ViewBag.Token as string ?? "";
}

<div class="bg-primary text-white py-4">
    <div class="container">
        <h3 class="fw-bold mb-0">
            <i class="fas fa-envelope me-2"></i>My Inquiries
        </h3>
    </div>
</div>

<div class="container py-5">
    <div id="inquiriesList">
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Loading inquiries...</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const token = "@token";
        const inquiries = @Html.Raw(ViewBag.InquiriesJson ?? "[]");

        if (inquiries.length > 0) {
            document.getElementById('inquiriesList').innerHTML = inquiries.map(i => `
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-8">
                                <h6 class="fw-bold">
                                    <i class="fas fa-comment me-2 text-primary"></i>
                                    My Message
                                </h6>
                                <p class="text-muted">${i.message}</p>
                                ${i.reply ? `
                                    <div class="alert alert-success">
                                        <h6 class="fw-bold">
                                            <i class="fas fa-reply me-2"></i>Agent Reply
                                        </h6>
                                        <p class="mb-0">${i.reply}</p>
                                    </div>
                                ` : `
                                    <div class="alert alert-warning">
                                        <i class="fas fa-clock me-2"></i>
                                        Waiting for agent reply...
                                    </div>
                                `}
                            </div>
                            <div class="col-md-4 text-end">
                                <span class="badge ${i.isReplied ? 'bg-success' : 'bg-warning text-dark'} mb-2">
                                    ${i.isReplied ? '✅ Replied' : '⏳ Pending'}
                                </span>
                                <p class="text-muted small">
                                    <i class="fas fa-calendar me-1"></i>
                                    ${new Date(i.createdAt).toLocaleDateString()}
                                </p>
                                <a href="/Home/PropertyDetail/${i.propertyId}"
                                    class="btn btn-sm btn-outline-primary">
                                    View Property
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        } else {
            document.getElementById('inquiriesList').innerHTML = `
                <div class="text-center py-5">
                    <i class="fas fa-envelope-open fa-3x text-muted mb-3"></i>
                    <h5 class="text-muted">No inquiries yet!</h5>
                    <a href="/Home/Properties" class="btn btn-primary mt-2">
                        Browse Properties
                    </a>
                </div>`;
        }
    </script>
}