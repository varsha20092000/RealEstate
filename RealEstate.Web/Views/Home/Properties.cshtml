@{
    ViewData["Title"] = "Properties";
    var city = ViewBag.City as string ?? "";
    var propType = ViewBag.PropertyType as string ?? "";
    var listType = ViewBag.ListingType as string ?? "";
}

<div class="bg-primary text-white py-4">
    <div class="container">
        <h2 class="fw-bold mb-0"><i class="fas fa-building me-2"></i>All Properties</h2>
    </div>
</div>

<!-- Elasticsearch Full-text Search -->
<div class="bg-white py-3 border-bottom shadow-sm">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-primary text-white border-primary">
                        <i class="fas fa-search"></i>
                    </span>
                    <input type="text" id="fulltextSearch" class="form-control border-primary"
                           placeholder="🔍 Search anything "
                           oninput="debounceSearch(this.value)" />
                    <button class="btn btn-outline-secondary" onclick="clearSearch()">
                        <i class="fas fa-times"></i> Clear
                    </button>
                </div>
                <small class="text-muted ms-1">
                    <i class="fas fa-bolt text-warning"></i>
                   
                </small>
            </div>
        </div>
    </div>
</div>

<!-- SQL Filter Search -->
<div class="bg-light py-4">
    <div class="container">
        <form action="/Home/Properties" method="get">
            <div class="row g-3">
                <div class="col-md-2">
                    <input type="text" name="city" class="form-control"
                           placeholder="City" value="@city" />
                </div>
                <div class="col-md-2">
                    <select name="propertyType" class="form-select">
                        <option value="">Property Type</option>
                        <option value="Villa">Villa</option>
                        <option value="Apartment">Apartment</option>
                        <option value="House">House</option>
                        <option value="Plot">Plot</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="listingType" class="form-select">
                        <option value="">Listing Type</option>
                        <option value="Sale">Sale</option>
                        <option value="Rent">Rent</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="number" name="minPrice" class="form-control"
                           placeholder="Min Price" value="@ViewBag.MinPrice" />
                </div>
                <div class="col-md-2">
                    <input type="number" name="maxPrice" class="form-control"
                           placeholder="Max Price" value="@ViewBag.MaxPrice" />
                </div>
                <div class="col-md-1">
                    <select name="bedrooms" class="form-select">
                        <option value="">Beds</option>
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-filter"></i>
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Properties Grid -->
<div class="container py-5">
    <div id="searchBadge" style="display:none;"></div>
    <div class="row g-4" id="propertiesGrid">
        <div class="col-12 text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Loading...</p>
        </div>
    </div>
    <div id="pagination" class="d-flex justify-content-center mt-4 gap-2"></div>
</div>

@section Scripts {
    <script>
        const json = @Html.Raw(ViewBag.PropertiesJson ?? "null");
        const currentPage = @(ViewBag.Page ?? 1);
        let searchTimeout = null;
        let originalProperties = null;

        function renderProperties(properties, isPaged) {
            if (!properties || properties.length === 0) {
                document.getElementById('propertiesGrid').innerHTML = `
                    <div class="col-12 text-center py-5">
                        <i class="fas fa-search fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">No properties found!</h5>
                        <a href="/Home/Properties" class="btn btn-primary mt-2">Clear Filters</a>
                    </div>`;
                document.getElementById('pagination').innerHTML = '';
                return;
            }

            document.getElementById('propertiesGrid').innerHTML = properties.map(p => `
                <div class="col-md-4">
                    <div class="card property-card shadow-sm h-100">
                        <div class="position-relative">
                            <div class="property-img bg-light" style="overflow:hidden;">
                                ${p.imageUrls && p.imageUrls.length > 0 ? `
                                    <img src="https://localhost:7056${p.imageUrls[0]}"
                                        class="w-100 h-100" style="object-fit:cover;" />
                                ` : `
                                    <i class="fas fa-home fa-3x text-secondary"></i>
                                `}
                            </div>
                            <span class="badge bg-primary badge-type">${p.propertyType}</span>
                            <span class="badge bg-${p.listingType === 'Sale' ? 'success' : 'info'} badge-featured">
                                ${p.listingType}
                            </span>
                        </div>
                        <div class="card-body">
                            <h6 class="card-title fw-bold">${p.title}</h6>
                            <p class="text-muted small">
                                <i class="fas fa-map-marker-alt me-1"></i>${p.address}, ${p.city}
                            </p>
                            <div class="price-tag">₹${p.price.toLocaleString('en-IN')}</div>
                            <div class="d-flex gap-3 mt-2 text-muted small">
                                <span><i class="fas fa-bed me-1"></i>${p.bedrooms} Beds</span>
                                <span><i class="fas fa-bath me-1"></i>${p.bathrooms} Baths</span>
                                <span><i class="fas fa-ruler-combined me-1"></i>${p.areaSqFt} sqft</span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0">
                            <a href="/Home/PropertyDetail/${p.id}" class="btn btn-primary w-100">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        // Initial load
        if (json && json.data && json.data.length > 0) {
            originalProperties = json.data;
            renderProperties(json.data, true);

            if (json.totalPages > 1) {
                let pages = '';
                for (let i = 1; i <= json.totalPages; i++) {
                    pages += `<a href="?page=${i}" class="btn ${i === currentPage ?
                        'btn-primary' : 'btn-outline-primary'}">${i}</a>`;
                }
                document.getElementById('pagination').innerHTML = pages;
            }
        } else {
            renderProperties([], false);
        }

        // Elasticsearch search with debounce
        function debounceSearch(value) {
            clearTimeout(searchTimeout);
                         if (value.length === 0) {
            clearSearch();
            return;
        }
        if (value.length < 3) return;
        searchTimeout = setTimeout(() => fulltextSearch(value), 300);
        }

        async function fulltextSearch(query) {
            document.getElementById('propertiesGrid').innerHTML = `
                <div class="col-12 text-center py-3">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2 text-muted">Searching...</p>
                </div>`;

            try {
                const response = await fetch(
                    `https://localhost:7056/api/Properties/fulltext?q=${encodeURIComponent(query)}`);
                const results = await response.json();

             document.getElementById('pagination').innerHTML = '';

                renderProperties(results, false);
            } catch (e) {
                console.error('Search error:', e);
            }
        }

        function clearSearch() {
            document.getElementById('fulltextSearch').value = '';
            document.getElementById('searchBadge').style.display = 'none';
            if (originalProperties) {
                renderProperties(originalProperties, true);
            }
        }
    </script>
}